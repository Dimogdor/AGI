# dépendances & artefacts de build (régénérés par `npm run build`)
node_modules/
www/
dist-pc/
dist-ota/
dist-apk/

# projet iOS généré localement (créé par `npx cap add ios`, nécessite Xcode)
# android/ EST versionné : il contient des personnalisations manuelles
# (plein écran immersif dans MainActivity, verrou paysage, icônes, splash,
# branchement de la signature de release). android/.gitignore exclut les builds.
ios/

# divers
.DS_Store
*.log
.env

# secrets de signature Android — NE JAMAIS committer (perte = ne plus jamais
# pouvoir publier de mise à jour de l'app sous le même appId)
android-signing/
